{% if series %}
  {% set seriesKey = series.key or series %}
  {% set seriesTitle = series.title or seriesKey %}
  {% set seriesIntro = series.intro %}
  {% set seriesUrl = series.url %}
  {% set seriesPosts = collections.post | postsInSeries(series) %}
  {% set seriesPosition = seriesPosts | getCollectionIndex(page) %}

  <section aria-labelledby="post-series" class="mb-8 rounded-md border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 p-4 md:p-5">
      <h2 id="post-series" class="body-s font-semibold mb-2">
          Series{% if seriesTitle %}: {{ seriesTitle }}{% endif %}
      </h2>

      <p class="body-s text-slate-700 dark:text-slate-300">
          {% if seriesIntro %}
              {{ seriesIntro }}
          {% else %}
              This post is part of a short series{% if seriesTitle %} on {{ seriesTitle | lower }}{% endif %}.
          {% endif %}
      </p>

      {% if seriesPosts.length > 1 %}
          <p class="body-xs text-slate-600 dark:text-slate-400">
              Post {{ seriesPosition }} of {{ seriesPosts.length }}
          </p>
      {% endif %}

      {% if seriesUrl %}
          <p class="body-xs mt-2">
              <a href="{{ seriesUrl }}" class="text-link">View all posts in this series</a>
          </p>
      {% endif %}
  </section>
{% endif %}
